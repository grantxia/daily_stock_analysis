# Daily A-share fundamentals push (GitHub Actions Secrets)
# Repo Settings -> Secrets and variables -> Actions -> Secrets

# Must-have notification
FEISHU_WEBHOOK_URL=

# Optional Feishu security (only if your bot enabled these checks)
FEISHU_WEBHOOK_SECRET=
FEISHU_WEBHOOK_KEYWORD=

# Must-have model key: fill at least one provider
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# NVIDIA as primary (OpenAI-compatible)
# OPENAI_API_KEY=<your NVIDIA API key>
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=meta/llama-3.1-70b-instruct

# DeepSeek as fallback provider key
DEEPSEEK_API_KEY=

# Recommended for better A-share fundamentals completeness
TUSHARE_TOKEN=
